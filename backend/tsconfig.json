{
  "compilerOptions": {
    "rootDir": "./",
    "outDir": "./build",
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "removeComments": false,
    "types": ["node"]
  }
}
