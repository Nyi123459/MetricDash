{
  "compilerOptions": {
    "rootDir": "./",
    "outDir": "./build",
    "target": "ES2020",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "removeComments": false
  },
  "exclude": ["node_modules"]
}
